  <Target Name="BuildEmbeddedLauncherUpdater" Condition="'$(DesignTimeBuild)' != 'true'">
    <MSBuild Projects="$(MSBuildProjectDirectory)\SmartGoldbergEmu.LauncherUpdate\SmartGoldbergEmu.LauncherUpdate.csproj" Properties="Configuration=$(Configuration);Platform=$(Platform)" Targets="Restore;Build" />
    <PropertyGroup>
      <_LauncherUpdaterBuildOutput>$(MSBuildProjectDirectory)\SmartGoldbergEmu.LauncherUpdate\bin\$(Configuration)\SmartGoldbergEmu.LauncherUpdate.exe</_LauncherUpdaterBuildOutput>
      <_LauncherUpdaterEmbedStaging>$(MSBuildProjectDirectory)\Resources\Embedded\SmartGoldbergEmu.LauncherUpdate.exe</_LauncherUpdaterEmbedStaging>
    </PropertyGroup>
    <Error Condition="!Exists('$(_LauncherUpdaterBuildOutput)')" Text="Launcher updater was not built: $(_LauncherUpdaterBuildOutput)" />
    <MakeDir Directories="$(MSBuildProjectDirectory)\Resources\Embedded" />
    <Copy SourceFiles="$(_LauncherUpdaterBuildOutput)" DestinationFiles="$(_LauncherUpdaterEmbedStaging)" SkipUnchangedFiles="true" />
    <Error Condition="!Exists('$(_LauncherUpdaterEmbedStaging)')" Text="Failed to stage launcher updater for embed: $(_LauncherUpdaterEmbedStaging)" />
    <ItemGroup>
      <EmbeddedResource Include="$(_LauncherUpdaterEmbedStaging)">
        <LogicalName>SmartGoldbergEmu.LauncherUpdate.exe</LogicalName>
      </EmbeddedResource>
    </ItemGroup>
  </Target>
